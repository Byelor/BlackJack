<div class="auth-page">
    <div class="card auth-card">
        <h1 class="page-title">Вход</h1>
        <p class="page-subtitle">Войдите в аккаунт, чтобы играть</p>

        <form id="login-form" class="form" method="POST" action="/api/login">
            <div class="form-group">
                <label for="nickname-input">Никнейм или email</label>
                <input type="text" name="nickname" id="nickname-input" class="input" autocomplete="username" required>
            </div>
            <div class="form-group">
                <label for="password-input">Пароль</label>
                <input type="password" id="password-input" name="password" class="input" autocomplete="current-password" required>
            </div>
            <button type="submit" class="btn btn--primary btn--block">Войти</button>
        </form>

        <p id="login-status" class="form-status"></p>

        <p class="auth-divider">
            Нет аккаунта? <a href="/authorization/register">Зарегистрироваться</a>
        </p>
    </div>
</div>

{{#contentFor "scripts"}}
    {{> (lookup @root "scripts")}}
{{/contentFor}}
