<main class="lobby">
    <section class="lobby-create">
        <h2>Создать комнату</h2>
        <form id="create-room-form" class="lobby-form">
            <label>
                Название
                <input name="name" type="text" required maxlength="64" placeholder="Мой стол" />
            </label>
            <label>
                Описание
                <input name="description" type="text" maxlength="200" placeholder="Необязательно" />
            </label>
            <label>
                Макс. игроков
                <input name="maxPlayersCount" type="number" min="2" max="7" value="5" />
            </label>
            <label>
                Колод в шузе
                <input name="deckCount" type="number" min="1" max="8" value="6" />
            </label>
            <label class="lobby-checkbox">
                <input name="isPrivate" type="checkbox" id="is-private" />
                Приватная комната
            </label>
            <label id="password-field" class="lobby-password hidden">
                Пароль
                <input name="password" type="password" maxlength="32" autocomplete="new-password" />
            </label>
            <button type="submit" id="create-room-btn">Создать и войти</button>
        </form>
        <p id="create-room-error" class="lobby-error hidden" role="alert"></p>
    </section>

    <section class="lobby-list">
        <div class="lobby-list-header">
            <h2>Комнаты</h2>
            <button type="button" id="update">Обновить</button>
        </div>
        <ul id="rooms-list"></ul>
        <p id="rooms-empty" class="lobby-empty hidden">Пока нет комнат — создайте первую.</p>
    </section>
</main>

{{#contentFor "styles"}}
    <link rel="stylesheet" href="/css/lobby.css">
{{/contentFor}}

{{#contentFor "scripts"}}
    <script src="/scripts/lobbyRoomsScript.js"></script>
{{/contentFor}}
